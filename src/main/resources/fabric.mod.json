{
  "schemaVersion": 1,
  "id": "minenav",
  "version": "${version}",
  "name": "minenav",
  "description": "A Minecraft pathfinding mod using A* and Anytime D* algorithms for automated navigation",
  "authors": [
    "ratmuds"
  ],
  "contact": {
    "homepage": "https://github.com/ratmuds/minenav",
    "sources": "https://github.com/ratmuds/minenav"
  },
  "license": "MIT",
  "icon": "assets/minenav/icon.png",
  "environment": "client",
  "entrypoints": {
    "fabric-datagen": [
      "org.ratmuds.minenav.client.MinenavDataGenerator"
    ],
    "client": [
      "org.ratmuds.minenav.client.MinenavClient"
    ],
    "main": [
      "org.ratmuds.minenav.Minenav"
    ]
  },
  "mixins": [
    "minenav.mixins.json",
    {
      "config": "minenav.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
}
